generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============ COMMERÇANT ============
model Business {
  id            String   @id @default(cuid())
  name          String
  email         String   @unique
  passwordHash  String
  phone         String?
  address       String?
  city          String?
  googlePlaceId String?  // Pour la redirection avis Google
  googleReviewUrl String? // URL directe vers Google Reviews
  plan          Plan     @default(ESSENTIAL)
  stripeCustomerId String?
  stripeSubscriptionId String?
  smsQuota      Int      @default(100)
  smsUsed       Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  customers     Customer[]
  reviews       Review[]
  smsCampaigns  SmsCampaign[]
  smsLogs       SmsLog[]
}

enum Plan {
  TRIAL
  ESSENTIAL
  PRO
}

// ============ CLIENT DU COMMERÇANT ============
model Customer {
  id         String   @id @default(cuid())
  businessId String
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  firstName  String
  lastName   String?
  phone      String
  email      String?
  visitCount Int      @default(0)
  lastVisit  DateTime?
  createdAt  DateTime @default(now())

  reviews    Review[]
  smsLogs    SmsLog[]

  @@unique([businessId, phone])
}

// ============ AVIS / FEEDBACK ============
model Review {
  id         String     @id @default(cuid())
  businessId String
  business   Business   @relation(fields: [businessId], references: [id], onDelete: Cascade)
  customerId String?
  customer   Customer?  @relation(fields: [customerId], references: [id])
  rating     Int        // 1 à 5
  comment    String?
  type       ReviewType // GOOGLE = redirigé vers Google, PRIVATE = feedback privé
  status     ReviewStatus @default(PENDING)
  smsLogId   String?    // Lien vers le SMS qui a déclenché l'avis
  createdAt  DateTime   @default(now())
}

enum ReviewType {
  GOOGLE
  PRIVATE
}

enum ReviewStatus {
  PENDING
  TREATED
  ARCHIVED
}

// ============ CAMPAGNES SMS ============
model SmsCampaign {
  id         String   @id @default(cuid())
  businessId String
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  name       String
  message    String   // Template du SMS avec variables {firstName}, {businessName}
  sentCount  Int      @default(0)
  openCount  Int      @default(0)
  reviewCount Int     @default(0)
  status     CampaignStatus @default(DRAFT)
  scheduledAt DateTime?
  sentAt     DateTime?
  createdAt  DateTime @default(now())

  smsLogs    SmsLog[]
}

enum CampaignStatus {
  DRAFT
  SCHEDULED
  SENDING
  SENT
}

// ============ LOGS SMS INDIVIDUELS ============
model SmsLog {
  id           String    @id @default(cuid())
  businessId   String
  business     Business  @relation(fields: [businessId], references: [id], onDelete: Cascade)
  customerId   String
  customer     Customer  @relation(fields: [customerId], references: [id])
  campaignId   String?
  campaign     SmsCampaign? @relation(fields: [campaignId], references: [id])
  phone        String
  message      String
  status       SmsStatus @default(SENT)
  twilioSid    String?   // ID Twilio pour le tracking
  sentAt       DateTime  @default(now())
  openedAt     DateTime?
  reviewedAt   DateTime?
}

enum SmsStatus {
  PENDING
  SENT
  DELIVERED
  OPENED
  REVIEWED
  FAILED
}
